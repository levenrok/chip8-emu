    "style": "npm run style --workspace demo",
    "style:check": "npm run style:check --workspace demo"
  },
  "keywords": [
    "rust",
    "low-level",
    "emulator",
    "interpreter",
    "chip8",
    "chip8-emulator",
    "chip8-interpreter",
    "wasm",
    "webassembly"
  ],
  "author": "levenrok",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "demo",
    "pkg"
  ]
